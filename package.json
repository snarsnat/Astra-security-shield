{
  "name": "astra-shield",
  "version": "2.1.5",
  "description": "Invisible bot detection & human verification — the best security is the security you never notice",
  "type": "module",
  "main": "src/index.js",
  "module": "src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./shield-server": "./server/index.js",
    "./dashboard": "./dashboard/server.js",
    "./astra.css": "./src/astra.css"
  },
  "bin": {
    "astra": "cli/astra.js"
  },
  "files": [
    "cli/",
    "server/",
    "dashboard/",
    "src/",
    "ui-challenges/",
    "postinstall.js",
    "astra-setup.js",
    "astra.config.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev:server": "node server/index.js",
    "dev:dashboard": "node dashboard/server.js",
    "dashboard": "node cli/astra.js dashboard",
    "start": "node cli/astra.js dashboard start",
    "stop": "node cli/astra.js dashboard stop",
    "status": "node cli/astra.js dashboard status",
    "test": "node -e \"import('./src/index.js').then(m => { if (!m.ASTRAShield) throw new Error('missing ASTRAShield export'); console.log('ok: exports load'); })\"",
    "postinstall": "node -e \"try{import('./postinstall.js')}catch(e){}\" || true",
    "prepublishOnly": "npm test"
  },
  "keywords": [
    "security",
    "bot-detection",
    "captcha",
    "invisible-verification",
    "human-verification",
    "accessibility",
    "behavioral-analysis",
    "fingerprinting",
    "cli",
    "astra",
    "shield",
    "web-security",
    "fraud-prevention"
  ],
  "author": "Nausheen Suraj",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/snarsnat/Astra-security-shield.git"
  },
  "bugs": {
    "url": "https://github.com/snarsnat/Astra-security-shield/issues"
  },
  "homepage": "https://astra-shield-site.vercel.app",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "blake3": "^2.1.7",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "crypto-js": "^4.2.0",
    "express": "^4.18.2",
    "geoip-lite": "^1.4.10",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "nanoid": "^5.0.4",
    "open": "^10.1.0",
    "simhash-js": "^1.0.0",
    "useragent": "^2.3.0",
    "zod": "^3.22.4"
  },
  "directories": {
    "example": "examples"
  }
}
